{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.aaif.io/wauth/rar/wauth-action-requirements-details/v0.1",
  "title": "WAUTH Authorization Details Type: Action Capability (Requirements Template)",
  "type": "object",
  "required": [
    "type",
    "actions",
    "locations",
    "action_profile",
    "hash_alg"
  ],
  "properties": {
    "type": {
      "type": "string",
      "const": "https://schemas.aaif.io/wauth/rar/wauth-action-authorization-details/v0.1",
      "description": "Uses the same RFC 9396 type identifier as the granted capability, but with relaxed requirements (action_hash MAY be omitted in templates)."
    },
    "actions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      },
      "description": "Intended action(s) covered by this capability."
    },
    "locations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "format": "uri"
      },
      "description": "Protected resource locations to which this capability applies (RFC 9396 common field)."
    },
    "action_profile": {
      "type": "string",
      "description": "Registry key for canonicalizing the action instance prior to hashing."
    },
    "hash_alg": {
      "type": "string",
      "enum": [
        "S256"
      ],
      "description": "Hash algorithm for action_hash; S256 denotes SHA-256."
    },
    "action_hash": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_-]{16,}$",
      "description": "OPTIONAL in requirements templates. If omitted, RP MUST provide action_hash via wauth_binding when denying a concrete request."
    },
    "envelope": {
      "type": "object",
      "description": "Optional envelope constraints (least privilege).",
      "properties": {
        "currency": {
          "type": "string",
          "minLength": 3,
          "maxLength": 3
        },
        "max_amount_minor": {
          "type": "integer",
          "minimum": 0
        },
        "max_total_amount_minor": {
          "type": "integer",
          "minimum": 0
        },
        "merchant_id": {
          "type": "string"
        },
        "mcc": {
          "type": "string"
        },
        "shipping_country": {
          "type": "string",
          "minLength": 2,
          "maxLength": 2
        },
        "max_uses": {
          "type": "integer",
          "minimum": 1
        }
      },
      "additionalProperties": true
    },
    "assurance": {
      "type": "object",
      "description": "Minimum assurance requirements (RP-side).",
      "properties": {
        "min_pohp": {
          "type": "integer",
          "minimum": 0,
          "maximum": 5
        },
        "accepted_pp_profiles": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "freshness_seconds": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "constraints": {
      "type": "object",
      "description": "Additional RP constraints (optional).",
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
